<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Gr8Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/colorAccent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_assessment_green"
            android:contentDescription="Assessment Placeholder" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:fontFamily="@font/lexend"
            android:textColor="@color/colorText"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Assessment 1" />

        <ImageView
            android:id="@+id/ivArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_proceed_green"
            android:contentDescription="Proceed" />

        <ImageButton
            android:id="@+id/ibEditAssessment"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit Assessment"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_edit"
            app:tint="#0A7F93" />

        <ImageButton
            android:id="@+id/ibDeleteAssessment"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete Assessment"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_remove"
            app:tint="#0A7F93" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>